#!/usr/bin/env dash

# ^c$var^ = fg color
# ^b$var^ = bg color

interval=0

# load colors
. ~/.local/bin/srwm-scripts/themes/vague

battery() {
  get_capacity="$(cat /sys/class/power_supply/BAT0/capacity)"
  printf "^c$black^ ^b$yellow^ 󱐋 ^b$darkyellow^ $get_capacity "
}

brightness() {
  printf "^c$black^^b$red^   ^b$darkred^ %.0f%%\n" $(cat /sys/class/backlight/*/brightness)
}

volume() {
    # Get volume and mute status from wpctl
    # Output format is usually: Volume: 0.45 [MUTED]
    wp_info=$(wpctl get-volume @DEFAULT_AUDIO_SINK@)
    
    if [ $? -eq 0 ]; then
        # Extract volume and convert decimal (0.45) to percentage (45)
        # Using awk for cleaner parsing
        vol_raw=$(echo "$wp_info" | awk '{print $2}')
        vol_int=$(echo "$vol_raw * 100 / 1" | bc) 
        
        # Check if muted (wp_info contains "[MUTED]")
        if echo "$wp_info" | grep -q "\[MUTED\]"; then
            printf "^c$black^ ^b$red^ 󰝟 Muted"
        else
            if [ "$vol_int" -eq 0 ]; then
                printf "^c$black^ ^b$green^ 󰝟 %s" "^b$darkgreen^ $vol_int%"
            elif [ "$vol_int" -le 33 ]; then
                printf "^c$black^ ^b$green^ 󰕿 %s" "^b$darkgreen^ $vol_int%"
            elif [ "$vol_int" -le 66 ]; then
                printf "^c$black^ ^b$green^ 󰖀 %s" "^b$darkgreen^ $vol_int%"
            else
                printf "^c$black^ ^b$green^ 󰕾 %s" "^b$darkgreen^ $vol_int%"
            fi
        fi
    else
        printf "^c$black^ ^b$red^ 󰝟 Error"
    fi
}
wlan() {
  wifi_interface=$(find /sys/class/net -name 'wl*' -type l | head -1 | xargs basename 2>/dev/null)
  ssid=$(iw dev $wifi_interface info 2>/dev/null | grep -Po '(?<=ssid ).*')
	case "$(cat /sys/class/net/wl*/operstate 2>/dev/null)" in
	up) printf "^c$black^ ^b$blue^ 󰤨  ^b$darkblue^ $ssid" ;;
	down) printf "^c$black^ ^b$blue^ 󰤭  ^b$darkblue^ Disconnected" ;;
	esac
}

clock() {
	printf "^c$black^ ^b$purple^ 󱑆  ^b$darkpurple^ $(date '+%H:%M:%S')"
}

gap() {
	printf "^c$black^ ^b$black^"
}

# refresh function
refresh() {
    # Update the root window name immediately
    xsetroot -name "$(brightness)$(gap)$(volume)$(gap)$(wlan)$(gap)$(clock)$(gap)$(battery)"
}

# Trap the ALRM signal to run the refresh
# When the script receives SIGALRM, it runs 'refresh'
trap refresh ALRM

while true; do
  refresh
  # Sleep in the background and wait for it to finish OR be killed
  sleep 1 & 
  wait $!
done
